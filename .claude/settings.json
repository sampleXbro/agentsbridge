{
  "permissions": {
    "allow": [
      "Bash(pnpm build:*)",
      "Bash(pnpm test:*)",
      "Bash(git add:*)",
      "Bash(npx vitest:*)",
      "Bash(node -e \"console.log\\(['.windsurfrules', 'AGENTS.md'].sort\\(\\)\\)\")",
      "Bash(node -e \"console.log\\(['.windsurfrules', 'AGENTS.md'].sort\\(\\)\\)\":*)"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Running: $(jq -r '.tool_input.command' < /dev/stdin)\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | xargs eslint --fix"
          }
        ]
      }
    ]
  }
}