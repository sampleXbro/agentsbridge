  "required": [
    "version",
    "targets",
    "features",
    "extends",
    "overrides",
    "collaboration"
  ],
  "additionalProperties": false,
  "title": "agentsmesh.yaml",
  "description": "AgentsMesh configuration file (agentsmesh.yaml / agentsmesh.local.yaml)"
}
